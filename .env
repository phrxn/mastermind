#================= MariaDB Configuration =================

#Porta do MariaDB exposta no host (não é a porta interna do container).
#Através dessa porta, podemos acessar o banco de dados do container.
#Use valor diferente de MARIADB_HOST_PORT_DB_TEST para evitar conflito (ex.: 3306).
#Ela deve ser uma porta livre no seu sistema, ou seja, que não esteja sendo usada por outro serviço.
MARIADB_HOST_PORT=

#Porta do MariaDB de teste exposta no host (não é a porta interna do container).
#Através dessa porta, podemos acessar o banco de dados do container.
#Use valor diferente de MARIADB_HOST_PORT para evitar conflito (ex.: 3307).
#Ela deve ser uma porta livre no seu sistema, ou seja, que não esteja sendo usada por outro serviço.
MARIADB_HOST_PORT_DB_TEST=

#Senha para o usuário root do MariaDB.
MARIADB_ROOT_PASSWORD=

#Nome do banco de dados a ser criado. Pode ser mastermind, por exemplo.
MARIADB_DATABASE=

#Nome do usuário do banco de dado. Pode ser mastermind, por exemplo.
MARIADB_USER=

#Senha do usuário do banco de dados. Pode ser mastermind123, por exemplo.
MARIADB_PASSWORD=


#================= JWT =================

#Secret key usada para assinar os tokens JWT. Deve ser uma string com pelo menos 32 caracteres.
JWT_SECRET=

#Tempo de expiração dos tokens JWT, em segundos.
JWT_EXPIRATION_SECONDS=